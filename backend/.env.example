# Database Configuration
DATABASE_URL=postgresql://rechargemax:rechargemax123@localhost:5432/rechargemax_db?sslmode=disable

# Server Configuration
PORT=8080
GIN_MODE=release

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# REQUIRED in production — must differ from JWT_SECRET: openssl rand -hex 32
ADMIN_JWT_SECRET=your-separate-admin-jwt-secret-change-in-production

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# VTPass Configuration
VTPASS_API_KEY=your_vtpass_api_key
VTPASS_PUBLIC_KEY=your_vtpass_public_key
VTPASS_SECRET_KEY=your_vtpass_secret_key
VTPASS_SANDBOX_MODE=true
VTPASS_BASE_URL=https://sandbox.vtpass.com/api

# CORS Configuration
# Production MUST include the exact frontend origin (protocol + hostname + port).
# Exact match only — wildcards and suffix matching are disabled (SEC-006).
# Example: ALLOWED_ORIGINS=https://rechargemax-frontend.onrender.com,https://app.rechargemax.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# Admin Configuration
ADMIN_DEFAULT_EMAIL=admin@rechargemax.ng
ADMIN_DEFAULT_PASSWORD=Admin@123
