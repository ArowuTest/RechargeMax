package services

import (
	"context"
	"database/sql"
	"fmt"
	"time"

	"github.com/google/uuid"
	"rechargemax/internal/domain/entities"
	"rechargemax/internal/domain/repositories"
)

// AffiliateServiceV2 is the enterprise-grade affiliate service with all fixes applied
type AffiliateServiceV2 struct {
	db                  *sql.DB
	affiliateRepo       repositories.AffiliateRepository
	commissionRepo      repositories.AffiliateCommissionRepository
	userRepo            repositories.UserRepository
	transactionRepo     repositories.TransactionRepository
	payoutService       *PayoutService
	notificationService *NotificationService
}

// NewAffiliateServiceV2 creates a new enterprise-grade affiliate service
func NewAffiliateServiceV2(
	db *sql.DB,
	affiliateRepo repositories.AffiliateRepository,
	commissionRepo repositories.AffiliateCommissionRepository,
	userRepo repositories.UserRepository,
	transactionRepo repositories.TransactionRepository,
	payoutService *PayoutService,
	notificationService *NotificationService,
) *AffiliateServiceV2 {
	return &AffiliateServiceV2{
		db:                  db,
		affiliateRepo:       affiliateRepo,
		commissionRepo:      commissionRepo,
		userRepo:            userRepo,
		transactionRepo:     transactionRepo,
		payoutService:       payoutService,
		notificationService: notificationService,
	}
}

// ProcessCommission processes commission for a transaction (ENTERPRISE VERSION)
// This version includes all fixes:
// - Currency in KOBO (integer)
// - First recharge validation (counts only RECHARGE transactions)
// - Commission limits enforcement
// - Tier-based commission rates
// - Fraud prevention
// - Reversal support
func (s *AffiliateServiceV2) ProcessCommission(ctx context.Context, transactionID uuid.UUID) error {
	// Start transaction
	tx, err := s.db.BeginTx(ctx, nil)
	if err != nil {
		return fmt.Errorf("failed to begin transaction: %w", err)
	}
	defer tx.Rollback()

	// 1. Get transaction details
	var transaction struct {
		ID          uuid.UUID
		UserID      uuid.UUID
		Amount      int    // In kobo
		Status      string
		RechargeType string
	}

	err = tx.QueryRowContext(ctx, `
		SELECT t.id, t.user_id, t.amount, t.status, vtu.recharge_type
		FROM transactions t
		INNER JOIN vtu_transactions vtu ON vtu.parent_transaction_id = t.id
		WHERE t.id = $1
	`, transactionID).Scan(
		&transaction.ID,
		&transaction.UserID,
		&transaction.Amount,
		&transaction.Status,
		&transaction.RechargeType,
	)

	if err == sql.ErrNoRows {
		return fmt.Errorf("transaction not found")
	}
	if err != nil {
		return fmt.Errorf("failed to get transaction: %w", err)
	}

	// 2. Check if transaction is successful
	if transaction.Status != "SUCCESS" {
		return nil // No commission for failed transactions
	}

	// 3. Get user and check if they have a referrer
	var user struct {
		ID         uuid.UUID
		ReferredBy *uuid.UUID
	}

	err = tx.QueryRowContext(ctx, `
		SELECT id, referred_by
		FROM users
		WHERE id = $1
	`, transaction.UserID).Scan(&user.ID, &user.ReferredBy)

	if err != nil {
		return fmt.Errorf("failed to get user: %w", err)
	}

	// No referrer = no commission
	if user.ReferredBy == nil {
		return nil
	}

	// 4. Get affiliate for referrer
	var affiliate struct {
		ID             uuid.UUID
		Status         string
		CommissionRate float64
		Tier           string
	}

	err = tx.QueryRowContext(ctx, `
		SELECT id, status, commission_rate, tier
		FROM affiliates
		WHERE user_id = $1
	`, user.ReferredBy).Scan(
		&affiliate.ID,
		&affiliate.Status,
		&affiliate.CommissionRate,
		&affiliate.Tier,
	)

	if err == sql.ErrNoRows {
		return nil // Referrer is not an affiliate
	}
	if err != nil {
		return fmt.Errorf("failed to get affiliate: %w", err)
	}

	// 5. Check if affiliate can earn commission (ISSUE #10 FIX)
	var canEarn bool
	err = tx.QueryRowContext(ctx, `
		SELECT can_affiliate_earn_commission($1)
	`, affiliate.ID).Scan(&canEarn)

	if err != nil || !canEarn {
		return nil // Affiliate is suspended or not approved
	}

	// 6. Check if this is the first recharge (ISSUE #8 FIX)
	// Use count_user_recharges function to count only RECHARGE transactions
	var rechargeCount int
	err = tx.QueryRowContext(ctx, `
		SELECT count_user_recharges($1)
	`, transaction.UserID).Scan(&rechargeCount)

	if err != nil {
		return fmt.Errorf("failed to count recharges: %w", err)
	}

	// Skip commission on first recharge
	if rechargeCount <= 1 {
		return nil
	}

	// 7. Calculate commission (ISSUE #1 FIX - amounts in KOBO)
	commissionAmount := int(float64(transaction.Amount) * (affiliate.CommissionRate / 100.0))

	// 8. Check commission limits (ISSUE #15 FIX)
	err = tx.QueryRowContext(ctx, `
		SELECT check_commission_limits($1, $2)
	`, affiliate.ID, commissionAmount).Scan(&canEarn)

	if err != nil {
		return fmt.Errorf("commission limit exceeded: %w", err)
	}

	// 9. Check for duplicate commission
	var existingCommission uuid.UUID
	err = tx.QueryRowContext(ctx, `
		SELECT id FROM affiliate_commissions
		WHERE transaction_id = $1 AND is_reversed = false
		LIMIT 1
	`, transactionID).Scan(&existingCommission)

	if err == nil {
		return nil // Commission already processed
	}

	// 10. Create commission record
	commissionID := uuid.New()
	_, err = tx.ExecContext(ctx, `
		INSERT INTO affiliate_commissions (
			id, affiliate_id, transaction_id, commission_amount,
			commission_rate, transaction_amount, status, created_at, updated_at
		) VALUES ($1, $2, $3, $4, $5, $6, $7, NOW(), NOW())
	`, commissionID, affiliate.ID, transactionID, commissionAmount,
		affiliate.CommissionRate, transaction.Amount, "PENDING")

	if err != nil {
		return fmt.Errorf("failed to create commission: %w", err)
	}

	// 11. Update affiliate total commission
	_, err = tx.ExecContext(ctx, `
		UPDATE affiliates
		SET total_commission = total_commission + $1,
		    updated_at = NOW()
		WHERE id = $2
	`, commissionAmount, affiliate.ID)

	if err != nil {
		return fmt.Errorf("failed to update affiliate: %w", err)
	}

	// 12. Log commission creation
	_, err = tx.ExecContext(ctx, `
		INSERT INTO gamification_audit_log (user_id, event_type, event_data)
		VALUES ($1, $2, $3)
	`, user.ReferredBy, "COMMISSION_EARNED", map[string]interface{}{
		"commission_id":   commissionID.String(),
		"affiliate_id":    affiliate.ID.String(),
		"transaction_id":  transactionID.String(),
		"amount":          commissionAmount,
		"rate":            affiliate.CommissionRate,
		"tier":            affiliate.Tier,
		"recharge_count":  rechargeCount,
	})

	if err != nil {
		return fmt.Errorf("failed to log commission: %w", err)
	}

	// Commit transaction
	if err := tx.Commit(); err != nil {
		return fmt.Errorf("failed to commit transaction: %w", err)
	}

	// 13. Send notification
	if s.notificationService != nil {
		var msisdn string
		err = s.db.QueryRowContext(ctx, "SELECT msisdn FROM users WHERE id = $1", user.ReferredBy).Scan(&msisdn)
		if err == nil {
			s.notificationService.SendMultiChannel(ctx, msisdn,
				"Commission Earned! 💰",
				fmt.Sprintf("You earned ₦%.2f commission (%s tier - %.1f%%) from a referral's recharge!",
					float64(commissionAmount)/100.0, affiliate.Tier, affiliate.CommissionRate),
				"affiliate",
				map[string]interface{}{
					"commission_id": commissionID.String(),
					"amount":        commissionAmount,
					"tier":          affiliate.Tier,
				},
			)
		}
	}

	return nil
}

// GetDashboardData returns comprehensive dashboard data for an affiliate
func (s *AffiliateServiceV2) GetDashboardData(ctx context.Context, userID uuid.UUID) (*AffiliateDashboard, error) {
	// Use the database function get_affiliate_dashboard_data
	var dashboard AffiliateDashboard

	err := s.db.QueryRowContext(ctx, `
		SELECT 
			total_referrals,
			active_referrals,
			total_commission,
			pending_commission,
			paid_commission,
			available_for_payout,
			current_tier,
			commission_rate,
			next_tier,
			referrals_to_next_tier
		FROM get_affiliate_dashboard_data($1)
	`, userID).Scan(
		&dashboard.TotalReferrals,
		&dashboard.ActiveReferrals,
		&dashboard.TotalCommission,
		&dashboard.PendingCommission,
		&dashboard.PaidCommission,
		&dashboard.AvailableForPayout,
		&dashboard.CurrentTier,
		&dashboard.CommissionRate,
		&dashboard.NextTier,
		&dashboard.ReferralsToNextTier,
	)

	if err != nil {
		return nil, fmt.Errorf("failed to get dashboard data: %w", err)
	}

	// Get recent commissions
	rows, err := s.db.QueryContext(ctx, `
		SELECT 
			ac.id,
			ac.commission_amount,
			ac.commission_rate,
			ac.transaction_amount,
			ac.status,
			ac.created_at,
			t.id as transaction_id,
			u.msisdn as referred_user_msisdn
		FROM affiliate_commissions ac
		INNER JOIN affiliates a ON a.id = ac.affiliate_id
		INNER JOIN transactions t ON t.id = ac.transaction_id
		INNER JOIN users u ON u.id = t.user_id
		WHERE a.user_id = $1
		AND ac.is_reversed = false
		ORDER BY ac.created_at DESC
		LIMIT 10
	`, userID)

	if err != nil {
		return nil, fmt.Errorf("failed to get recent commissions: %w", err)
	}
	defer rows.Close()

	var recentCommissions []CommissionDetail
	for rows.Next() {
		var comm CommissionDetail
		err := rows.Scan(
			&comm.ID,
			&comm.Amount,
			&comm.Rate,
			&comm.TransactionAmount,
			&comm.Status,
			&comm.CreatedAt,
			&comm.TransactionID,
			&comm.ReferredUserMSISDN,
		)
		if err != nil {
			return nil, fmt.Errorf("failed to scan commission: %w", err)
		}
		recentCommissions = append(recentCommissions, comm)
	}

	dashboard.RecentCommissions = recentCommissions

	return &dashboard, nil
}

// AffiliateDashboard represents complete dashboard data
type AffiliateDashboard struct {
	TotalReferrals       int                `json:"total_referrals"`
	ActiveReferrals      int                `json:"active_referrals"`
	TotalCommission      int                `json:"total_commission"`       // In kobo
	PendingCommission    int                `json:"pending_commission"`     // In kobo
	PaidCommission       int                `json:"paid_commission"`        // In kobo
	AvailableForPayout   int                `json:"available_for_payout"`   // In kobo
	CurrentTier          string             `json:"current_tier"`
	CommissionRate       float64            `json:"commission_rate"`
	NextTier             *string            `json:"next_tier"`
	ReferralsToNextTier  int                `json:"referrals_to_next_tier"`
	RecentCommissions    []CommissionDetail `json:"recent_commissions"`
}

// CommissionDetail represents a commission record
type CommissionDetail struct {
	ID                  uuid.UUID `json:"id"`
	Amount              int       `json:"amount"` // In kobo
	Rate                float64   `json:"rate"`
	TransactionAmount   int       `json:"transaction_amount"` // In kobo
	Status              string    `json:"status"`
	CreatedAt           time.Time `json:"created_at"`
	TransactionID       uuid.UUID `json:"transaction_id"`
	ReferredUserMSISDN  string    `json:"referred_user_msisdn"`
}

// GetTopAffiliates returns top performing affiliates
func (s *AffiliateServiceV2) GetTopAffiliates(ctx context.Context, limit int) ([]TopAffiliate, error) {
	rows, err := s.db.QueryContext(ctx, `
		SELECT 
			affiliate_id,
			user_id,
			affiliate_code,
			total_referrals,
			total_commission,
			tier,
			rank
		FROM get_top_affiliates($1)
	`, limit)

	if err != nil {
		return nil, fmt.Errorf("failed to get top affiliates: %w", err)
	}
	defer rows.Close()

	var topAffiliates []TopAffiliate
	for rows.Next() {
		var ta TopAffiliate
		err := rows.Scan(
			&ta.AffiliateID,
			&ta.UserID,
			&ta.AffiliateCode,
			&ta.TotalReferrals,
			&ta.TotalCommission,
			&ta.Tier,
			&ta.Rank,
		)
		if err != nil {
			return nil, fmt.Errorf("failed to scan affiliate: %w", err)
		}
		topAffiliates = append(topAffiliates, ta)
	}

	return topAffiliates, nil
}

// TopAffiliate represents a top performing affiliate
type TopAffiliate struct {
	AffiliateID     uuid.UUID `json:"affiliate_id"`
	UserID          uuid.UUID `json:"user_id"`
	AffiliateCode   string    `json:"affiliate_code"`
	TotalReferrals  int       `json:"total_referrals"`
	TotalCommission int       `json:"total_commission"` // In kobo
	Tier            string    `json:"tier"`
	Rank            int       `json:"rank"`
}

// ReverseCommission reverses a commission when a transaction is refunded
func (s *AffiliateServiceV2) ReverseCommission(ctx context.Context, transactionID uuid.UUID, reason string) error {
	// Use the database function reverse_affiliate_commission
	var reversalID *uuid.UUID
	err := s.db.QueryRowContext(ctx, `
		SELECT reverse_affiliate_commission($1, $2)
	`, transactionID, reason).Scan(&reversalID)

	if err != nil {
		return fmt.Errorf("failed to reverse commission: %w", err)
	}

	if reversalID == nil {
		return nil // No commission to reverse
	}

	// Send notification
	if s.notificationService != nil {
		// Get affiliate details
		var affiliateUserID uuid.UUID
		var commissionAmount int
		err = s.db.QueryRowContext(ctx, `
			SELECT a.user_id, ac.commission_amount
			FROM affiliate_commissions ac
			INNER JOIN affiliates a ON a.id = ac.affiliate_id
			WHERE ac.id = $1
		`, reversalID).Scan(&affiliateUserID, &commissionAmount)

		if err == nil {
			var msisdn string
			err = s.db.QueryRowContext(ctx, "SELECT msisdn FROM users WHERE id = $1", affiliateUserID).Scan(&msisdn)
			if err == nil {
				s.notificationService.SendMultiChannel(ctx, msisdn,
					"Commission Reversed",
					fmt.Sprintf("A commission of ₦%.2f was reversed. Reason: %s",
						float64(commissionAmount)/100.0, reason),
					"affiliate",
					map[string]interface{}{
						"reversal_id": reversalID.String(),
						"amount":      commissionAmount,
						"reason":      reason,
					},
				)
			}
		}
	}

	return nil
}

// GetCommissionTiers returns all commission tiers
func (s *AffiliateServiceV2) GetCommissionTiers(ctx context.Context) ([]CommissionTier, error) {
	rows, err := s.db.QueryContext(ctx, `
		SELECT tier, min_referrals, commission_rate, bonus_threshold, bonus_amount, description
		FROM affiliate_commission_tiers
		WHERE is_active = true
		ORDER BY min_referrals ASC
	`)

	if err != nil {
		return nil, fmt.Errorf("failed to get tiers: %w", err)
	}
	defer rows.Close()

	var tiers []CommissionTier
	for rows.Next() {
		var tier CommissionTier
		err := rows.Scan(
			&tier.Tier,
			&tier.MinReferrals,
			&tier.CommissionRate,
			&tier.BonusThreshold,
			&tier.BonusAmount,
			&tier.Description,
		)
		if err != nil {
			return nil, fmt.Errorf("failed to scan tier: %w", err)
		}
		tiers = append(tiers, tier)
	}

	return tiers, nil
}

// CommissionTier represents a commission tier
type CommissionTier struct {
	Tier            string   `json:"tier"`
	MinReferrals    int      `json:"min_referrals"`
	CommissionRate  float64  `json:"commission_rate"`
	BonusThreshold  *int     `json:"bonus_threshold"`
	BonusAmount     *int     `json:"bonus_amount"` // In kobo
	Description     string   `json:"description"`
}

// GetAffiliateAnalytics returns analytics for an affiliate
func (s *AffiliateServiceV2) GetAffiliateAnalytics(ctx context.Context, affiliateID uuid.UUID, startDate, endDate time.Time) ([]DailyAnalytics, error) {
	rows, err := s.db.QueryContext(ctx, `
		SELECT 
			analytics_date,
			total_clicks,
			unique_clicks,
			conversions,
			conversion_rate,
			total_commission,
			recharge_commissions,
			subscription_commissions
		FROM affiliate_analytics
		WHERE affiliate_id = $1
		AND analytics_date BETWEEN $2 AND $3
		ORDER BY analytics_date DESC
	`, affiliateID, startDate, endDate)

	if err != nil {
		return nil, fmt.Errorf("failed to get analytics: %w", err)
	}
	defer rows.Close()

	var analytics []DailyAnalytics
	for rows.Next() {
		var da DailyAnalytics
		err := rows.Scan(
			&da.Date,
			&da.TotalClicks,
			&da.UniqueClicks,
			&da.Conversions,
			&da.ConversionRate,
			&da.TotalCommission,
			&da.RechargeCommissions,
			&da.SubscriptionCommissions,
		)
		if err != nil {
			return nil, fmt.Errorf("failed to scan analytics: %w", err)
		}
		analytics = append(analytics, da)
	}

	return analytics, nil
}

// DailyAnalytics represents daily analytics data
type DailyAnalytics struct {
	Date                    time.Time `json:"date"`
	TotalClicks             int       `json:"total_clicks"`
	UniqueClicks            int       `json:"unique_clicks"`
	Conversions             int       `json:"conversions"`
	ConversionRate          float64   `json:"conversion_rate"`
	TotalCommission         int       `json:"total_commission"` // In kobo
	RechargeCommissions     int       `json:"recharge_commissions"` // In kobo
	SubscriptionCommissions int       `json:"subscription_commissions"` // In kobo
}
