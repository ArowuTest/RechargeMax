package services

import (
	"context"
	"database/sql"
	"encoding/json"
	"fmt"
	"io"
	"net/http"
	"strings"
	"time"

	"github.com/google/uuid"
	"rechargemax/internal/domain/entities"
	"rechargemax/internal/domain/repositories"
)

// PayoutService handles automated payout processing
type PayoutService struct {
	db                  *sql.DB
	affiliateRepo       repositories.AffiliateRepository
	payoutRepo          repositories.AffiliatePayoutRepository
	commissionRepo      repositories.AffiliateCommissionRepository
	bankAccountRepo     repositories.AffiliateBankAccountRepository
	paystackSecretKey   string
	paystackBaseURL     string
	notificationService *NotificationService
}

// NewPayoutService creates a new payout service instance
func NewPayoutService(
	db *sql.DB,
	affiliateRepo repositories.AffiliateRepository,
	payoutRepo repositories.AffiliatePayoutRepository,
	commissionRepo repositories.AffiliateCommissionRepository,
	bankAccountRepo repositories.AffiliateBankAccountRepository,
	paystackSecretKey string,
	notificationService *NotificationService,
) *PayoutService {
	return &PayoutService{
		db:                  db,
		affiliateRepo:       affiliateRepo,
		payoutRepo:          payoutRepo,
		commissionRepo:      commissionRepo,
		bankAccountRepo:     bankAccountRepo,
		paystackSecretKey:   paystackSecretKey,
		paystackBaseURL:     "https://api.paystack.co",
		notificationService: notificationService,
	}
}

// PayoutRequest represents a payout request
type PayoutRequest struct {
	AffiliateID uuid.UUID `json:"affiliate_id"`
	Amount      int       `json:"amount"` // In kobo
}

// PayoutResponse represents a payout response
type PayoutResponse struct {
	ID                uuid.UUID `json:"id"`
	AffiliateID       uuid.UUID `json:"affiliate_id"`
	Amount            int       `json:"amount"` // In kobo
	ProcessingFee     int       `json:"processing_fee"`
	NetAmount         int       `json:"net_amount"`
	Status            string    `json:"status"`
	TransferReference string    `json:"transfer_reference,omitempty"`
	TransferCode      string    `json:"transfer_code,omitempty"`
	CreatedAt         time.Time `json:"created_at"`
}

// InitiatePayout initiates a payout to an affiliate
func (s *PayoutService) InitiatePayout(ctx context.Context, req *PayoutRequest) (*PayoutResponse, error) {
	// Start transaction
	tx, err := s.db.BeginTx(ctx, nil)
	if err != nil {
		return nil, fmt.Errorf("failed to begin transaction: %w", err)
	}
	defer tx.Rollback()

	// 1. Validate affiliate exists and is approved
	affiliate, err := s.affiliateRepo.FindByID(ctx, req.AffiliateID)
	if err != nil {
		return nil, fmt.Errorf("affiliate not found: %w", err)
	}

	if affiliate.Status != "APPROVED" {
		return nil, fmt.Errorf("affiliate is not approved for payouts (status: %s)", affiliate.Status)
	}

	// 2. Get minimum payout amount from config
	var minPayoutAmount int
	err = tx.QueryRowContext(ctx, `
		SELECT (value::text)::integer 
		FROM system_config 
		WHERE key = 'affiliate_minimum_payout' AND is_public = false
	`).Scan(&minPayoutAmount)
	if err != nil {
		minPayoutAmount = 500000 // Default: ₦5,000
	}

	if req.Amount < minPayoutAmount {
		return nil, fmt.Errorf("amount below minimum payout threshold: ₦%.2f (minimum: ₦%.2f)", 
			float64(req.Amount)/100.0, float64(minPayoutAmount)/100.0)
	}

	// 3. Check available balance
	availableBalance := affiliate.TotalCommission
	
	// Subtract already paid amounts
	var totalPaid int
	err = tx.QueryRowContext(ctx, `
		SELECT COALESCE(SUM(total_amount), 0)
		FROM affiliate_payouts
		WHERE affiliate_id = $1 AND payout_status = 'COMPLETED'
	`, req.AffiliateID).Scan(&totalPaid)
	if err != nil {
		return nil, fmt.Errorf("failed to calculate paid amount: %w", err)
	}

	availableBalance -= totalPaid

	if req.Amount > availableBalance {
		return nil, fmt.Errorf("insufficient balance: requested ₦%.2f, available ₦%.2f",
			float64(req.Amount)/100.0, float64(availableBalance)/100.0)
	}

	// 4. Get processing fee from config
	var processingFee int
	err = tx.QueryRowContext(ctx, `
		SELECT (value::text)::integer 
		FROM system_config 
		WHERE key = 'affiliate_payout_processing_fee' AND is_public = false
	`).Scan(&processingFee)
	if err != nil {
		processingFee = 10000 // Default: ₦100
	}

	netAmount := req.Amount - processingFee

	// 5. Get verified primary bank account
	var bankAccount struct {
		ID            uuid.UUID
		BankName      string
		BankCode      string
		AccountNumber string
		AccountName   string
	}

	err = tx.QueryRowContext(ctx, `
		SELECT id, bank_name, bank_code, account_number, account_name
		FROM affiliate_bank_accounts
		WHERE affiliate_id = $1 
		AND is_verified = true 
		AND is_primary = true 
		AND is_active = true
		LIMIT 1
	`, req.AffiliateID).Scan(
		&bankAccount.ID,
		&bankAccount.BankName,
		&bankAccount.BankCode,
		&bankAccount.AccountNumber,
		&bankAccount.AccountName,
	)

	if err == sql.ErrNoRows {
		return nil, fmt.Errorf("no verified bank account found for affiliate")
	}
	if err != nil {
		return nil, fmt.Errorf("failed to get bank account: %w", err)
	}

	// 6. Create payout record
	payoutID := uuid.New()
	transferReference := fmt.Sprintf("PAYOUT-%s-%d", payoutID.String()[:8], time.Now().Unix())

	_, err = tx.ExecContext(ctx, `
		INSERT INTO affiliate_payouts (
			id, affiliate_id, total_amount, processing_fee, net_amount,
			payout_status, transfer_reference, created_at, updated_at
		) VALUES ($1, $2, $3, $4, $5, $6, $7, NOW(), NOW())
	`, payoutID, req.AffiliateID, req.Amount, processingFee, netAmount, "PENDING", transferReference)

	if err != nil {
		return nil, fmt.Errorf("failed to create payout record: %w", err)
	}

	// 7. Initiate Paystack transfer
	transferCode, err := s.initiatePaystackTransfer(ctx, &PaystackTransferRequest{
		Source:    "balance",
		Amount:    netAmount,
		Recipient: bankAccount.AccountNumber,
		Reason:    fmt.Sprintf("Affiliate commission payout - %s", transferReference),
		Reference: transferReference,
	})

	if err != nil {
		// Update payout status to FAILED
		_, _ = tx.ExecContext(ctx, `
			UPDATE affiliate_payouts 
			SET payout_status = 'FAILED', 
			    failure_reason = $1,
			    updated_at = NOW()
			WHERE id = $2
		`, err.Error(), payoutID)

		tx.Commit() // Commit the failed record
		return nil, fmt.Errorf("failed to initiate transfer: %w", err)
	}

	// 8. Update payout with transfer code
	_, err = tx.ExecContext(ctx, `
		UPDATE affiliate_payouts 
		SET transfer_code = $1, 
		    payout_status = 'PROCESSING',
		    updated_at = NOW()
		WHERE id = $2
	`, transferCode, payoutID)

	if err != nil {
		return nil, fmt.Errorf("failed to update payout: %w", err)
	}

	// 9. Mark commissions as pending payout
	_, err = tx.ExecContext(ctx, `
		UPDATE affiliate_commissions
		SET status = 'PROCESSING',
		    payout_id = $1,
		    updated_at = NOW()
		WHERE affiliate_id = $2 
		AND status = 'PENDING'
		AND is_reversed = false
		AND commission_amount <= $3
	`, payoutID, req.AffiliateID, req.Amount)

	if err != nil {
		return nil, fmt.Errorf("failed to update commissions: %w", err)
	}

	// Commit transaction
	if err := tx.Commit(); err != nil {
		return nil, fmt.Errorf("failed to commit transaction: %w", err)
	}

	// 10. Send notification
	if s.notificationService != nil && affiliate.UserID != nil {
		// Get user MSISDN
		var msisdn string
		err = s.db.QueryRowContext(ctx, "SELECT msisdn FROM users WHERE id = $1", affiliate.UserID).Scan(&msisdn)
		if err == nil {
			s.notificationService.SendMultiChannel(ctx, msisdn,
				"Payout Initiated 💰",
				fmt.Sprintf("Your payout of ₦%.2f is being processed. You'll receive ₦%.2f after processing fee.",
					float64(req.Amount)/100.0, float64(netAmount)/100.0),
				"affiliate",
				map[string]interface{}{
					"payout_id":          payoutID.String(),
					"amount":             req.Amount,
					"net_amount":         netAmount,
					"transfer_reference": transferReference,
				},
			)
		}
	}

	return &PayoutResponse{
		ID:                payoutID,
		AffiliateID:       req.AffiliateID,
		Amount:            req.Amount,
		ProcessingFee:     processingFee,
		NetAmount:         netAmount,
		Status:            "PROCESSING",
		TransferReference: transferReference,
		TransferCode:      transferCode,
		CreatedAt:         time.Now(),
	}, nil
}

// PaystackTransferRequest represents a Paystack transfer request
type PaystackTransferRequest struct {
	Source    string `json:"source"`
	Amount    int    `json:"amount"`
	Recipient string `json:"recipient"`
	Reason    string `json:"reason"`
	Reference string `json:"reference"`
}

// PaystackTransferResponse represents a Paystack transfer response
type PaystackTransferResponse struct {
	Status  bool   `json:"status"`
	Message string `json:"message"`
	Data    struct {
		TransferCode string `json:"transfer_code"`
		Reference    string `json:"reference"`
		Status       string `json:"status"`
	} `json:"data"`
}

// initiatePaystackTransfer initiates a transfer via Paystack API
func (s *PayoutService) initiatePaystackTransfer(ctx context.Context, req *PaystackTransferRequest) (string, error) {
	// Marshal request
	body, err := json.Marshal(req)
	if err != nil {
		return "", fmt.Errorf("failed to marshal request: %w", err)
	}

	// Create HTTP request
	httpReq, err := http.NewRequestWithContext(ctx, "POST", 
		fmt.Sprintf("%s/transfer", s.paystackBaseURL),
		strings.NewReader(string(body)))
	if err != nil {
		return "", fmt.Errorf("failed to create request: %w", err)
	}

	httpReq.Header.Set("Authorization", fmt.Sprintf("Bearer %s", s.paystackSecretKey))
	httpReq.Header.Set("Content-Type", "application/json")

	// Send request
	client := &http.Client{Timeout: 30 * time.Second}
	resp, err := client.Do(httpReq)
	if err != nil {
		return "", fmt.Errorf("failed to send request: %w", err)
	}
	defer resp.Body.Close()

	// Read response
	respBody, err := io.ReadAll(resp.Body)
	if err != nil {
		return "", fmt.Errorf("failed to read response: %w", err)
	}

	// Parse response
	var paystackResp PaystackTransferResponse
	if err := json.Unmarshal(respBody, &paystackResp); err != nil {
		return "", fmt.Errorf("failed to parse response: %w", err)
	}

	if !paystackResp.Status {
		return "", fmt.Errorf("paystack transfer failed: %s", paystackResp.Message)
	}

	return paystackResp.Data.TransferCode, nil
}

// HandlePaystackWebhook handles Paystack webhook events for transfer updates
func (s *PayoutService) HandlePaystackWebhook(ctx context.Context, event map[string]interface{}) error {
	eventType, ok := event["event"].(string)
	if !ok {
		return fmt.Errorf("invalid event type")
	}

	// Handle transfer events
	if eventType == "transfer.success" || eventType == "transfer.failed" || eventType == "transfer.reversed" {
		data, ok := event["data"].(map[string]interface{})
		if !ok {
			return fmt.Errorf("invalid event data")
		}

		reference, ok := data["reference"].(string)
		if !ok {
			return fmt.Errorf("missing transfer reference")
		}

		// Get payout by reference
		var payoutID uuid.UUID
		var affiliateID uuid.UUID
		var amount int
		err := s.db.QueryRowContext(ctx, `
			SELECT id, affiliate_id, total_amount
			FROM affiliate_payouts
			WHERE transfer_reference = $1
		`, reference).Scan(&payoutID, &affiliateID, &amount)

		if err == sql.ErrNoRows {
			return fmt.Errorf("payout not found for reference: %s", reference)
		}
		if err != nil {
			return fmt.Errorf("failed to get payout: %w", err)
		}

		// Update payout status based on event
		var newStatus string
		var failureReason string

		switch eventType {
		case "transfer.success":
			newStatus = "COMPLETED"
			
			// Mark commissions as PAID
			_, err = s.db.ExecContext(ctx, `
				UPDATE affiliate_commissions
				SET status = 'PAID',
				    paid_at = NOW(),
				    updated_at = NOW()
				WHERE payout_id = $1
			`, payoutID)

			if err != nil {
				return fmt.Errorf("failed to update commissions: %w", err)
			}

			// Send success notification
			if s.notificationService != nil {
				var msisdn string
				err = s.db.QueryRowContext(ctx, `
					SELECT u.msisdn 
					FROM users u
					INNER JOIN affiliates a ON a.user_id = u.id
					WHERE a.id = $1
				`, affiliateID).Scan(&msisdn)

				if err == nil {
					s.notificationService.SendMultiChannel(ctx, msisdn,
						"Payout Completed ✅",
						fmt.Sprintf("Your payout of ₦%.2f has been successfully transferred to your bank account!",
							float64(amount)/100.0),
						"affiliate",
						map[string]interface{}{
							"payout_id": payoutID.String(),
							"amount":    amount,
							"status":    "COMPLETED",
						},
					)
				}
			}

		case "transfer.failed":
			newStatus = "FAILED"
			if reason, ok := data["reason"].(string); ok {
				failureReason = reason
			} else {
				failureReason = "Transfer failed"
			}

			// Revert commissions to PENDING
			_, err = s.db.ExecContext(ctx, `
				UPDATE affiliate_commissions
				SET status = 'PENDING',
				    payout_id = NULL,
				    updated_at = NOW()
				WHERE payout_id = $1
			`, payoutID)

			if err != nil {
				return fmt.Errorf("failed to revert commissions: %w", err)
			}

			// Send failure notification
			if s.notificationService != nil {
				var msisdn string
				err = s.db.QueryRowContext(ctx, `
					SELECT u.msisdn 
					FROM users u
					INNER JOIN affiliates a ON a.user_id = u.id
					WHERE a.id = $1
				`, affiliateID).Scan(&msisdn)

				if err == nil {
					s.notificationService.SendMultiChannel(ctx, msisdn,
						"Payout Failed ❌",
						fmt.Sprintf("Your payout of ₦%.2f failed: %s. Please contact support.",
							float64(amount)/100.0, failureReason),
						"affiliate",
						map[string]interface{}{
							"payout_id": payoutID.String(),
							"amount":    amount,
							"reason":    failureReason,
						},
					)
				}
			}

		case "transfer.reversed":
			newStatus = "REVERSED"
			failureReason = "Transfer reversed"

			// Revert commissions to PENDING
			_, err = s.db.ExecContext(ctx, `
				UPDATE affiliate_commissions
				SET status = 'PENDING',
				    payout_id = NULL,
				    updated_at = NOW()
				WHERE payout_id = $1
			`, payoutID)

			if err != nil {
				return fmt.Errorf("failed to revert commissions: %w", err)
			}
		}

		// Update payout record
		_, err = s.db.ExecContext(ctx, `
			UPDATE affiliate_payouts
			SET payout_status = $1,
			    failure_reason = $2,
			    completed_at = CASE WHEN $1 = 'COMPLETED' THEN NOW() ELSE NULL END,
			    updated_at = NOW()
			WHERE id = $3
		`, newStatus, failureReason, payoutID)

		if err != nil {
			return fmt.Errorf("failed to update payout: %w", err)
		}

		// Log event
		_, err = s.db.ExecContext(ctx, `
			INSERT INTO gamification_audit_log (event_type, event_data)
			VALUES ($1, $2)
		`, "PAYOUT_"+newStatus, map[string]interface{}{
			"payout_id":    payoutID.String(),
			"affiliate_id": affiliateID.String(),
			"amount":       amount,
			"reference":    reference,
			"reason":       failureReason,
		})

		return nil
	}

	return nil
}

// GetPayoutHistory returns payout history for an affiliate
func (s *PayoutService) GetPayoutHistory(ctx context.Context, affiliateID uuid.UUID, limit, offset int) ([]*entities.AffiliatePayouts, int64, error) {
	// Get payouts
	rows, err := s.db.QueryContext(ctx, `
		SELECT id, affiliate_id, total_amount, processing_fee, net_amount,
		       payout_status, transfer_reference, transfer_code, completed_at,
		       failure_reason, retry_count, created_at, updated_at
		FROM affiliate_payouts
		WHERE affiliate_id = $1
		ORDER BY created_at DESC
		LIMIT $2 OFFSET $3
	`, affiliateID, limit, offset)

	if err != nil {
		return nil, 0, fmt.Errorf("failed to get payouts: %w", err)
	}
	defer rows.Close()

	var payouts []*entities.AffiliatePayouts
	for rows.Next() {
		var payout entities.AffiliatePayouts
		err := rows.Scan(
			&payout.ID,
			&payout.AffiliateID,
			&payout.TotalAmount,
			&payout.ProcessingFee,
			&payout.NetAmount,
			&payout.PayoutStatus,
			&payout.TransferReference,
			&payout.TransferCode,
			&payout.CompletedAt,
			&payout.FailureReason,
			&payout.RetryCount,
			&payout.CreatedAt,
			&payout.UpdatedAt,
		)
		if err != nil {
			return nil, 0, fmt.Errorf("failed to scan payout: %w", err)
		}
		payouts = append(payouts, &payout)
	}

	// Get total count
	var total int64
	err = s.db.QueryRowContext(ctx, `
		SELECT COUNT(*) FROM affiliate_payouts WHERE affiliate_id = $1
	`, affiliateID).Scan(&total)

	if err != nil {
		return nil, 0, fmt.Errorf("failed to get total count: %w", err)
	}

	return payouts, total, nil
}
