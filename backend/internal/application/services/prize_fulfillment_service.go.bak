package services

import (
	"context"
	"fmt"
	"time"

	"github.com/google/uuid"

	"rechargemax/internal/domain/entities"
	"rechargemax/internal/domain/repositories"
)

// PrizeFulfillmentMode represents the fulfillment mode for prizes
type PrizeFulfillmentMode string

const (
	FulfillmentModeAutoProvision PrizeFulfillmentMode = "auto_provision"
	FulfillmentModeManualClaim   PrizeFulfillmentMode = "manual_claim"
)

// PrizeFulfillmentConfig represents configuration for prize fulfillment
type PrizeFulfillmentConfig struct {
	PrizeType              string
	FulfillmentMode        PrizeFulfillmentMode
	AutoProvisionEnabled   bool
	RequireLoginToClaim    bool
	ClaimDeadlineDays      int
	AllowRetryOnFailure    bool
	MaxRetryAttempts       int
}

// PrizeFulfillmentService handles flexible prize fulfillment (auto or manual)
type PrizeFulfillmentService struct {
	winnerRepo               repositories.WinnerRepository
	telecomServiceIntegrated *TelecomServiceIntegrated
	hlrService               *HLRService
	notificationService      *NotificationService
	db                       interface{} // Database connection for config queries
}

// NewPrizeFulfillmentService creates a new prize fulfillment service
func NewPrizeFulfillmentService(
	winnerRepo repositories.WinnerRepository,
	telecomServiceIntegrated *TelecomServiceIntegrated,
	hlrService *HLRService,
	notificationService *NotificationService,
	db interface{},
) *PrizeFulfillmentService {
	return &PrizeFulfillmentService{
		winnerRepo:               winnerRepo,
		telecomServiceIntegrated: telecomServiceIntegrated,
		hlrService:               hlrService,
		notificationService:      notificationService,
		db:                       db,
	}
}

// GetFulfillmentConfig gets fulfillment configuration for a prize type
func (s *PrizeFulfillmentService) GetFulfillmentConfig(ctx context.Context, prizeType string) (*PrizeFulfillmentConfig, error) {
	// Query database for configuration
	// In production, this would query prize_fulfillment_config table
	// For now, return default config based on prize type
	
	config := &PrizeFulfillmentConfig{
		PrizeType:            prizeType,
		ClaimDeadlineDays:    30,
		AllowRetryOnFailure:  true,
		MaxRetryAttempts:     3,
	}
	
	switch prizeType {
	case "airtime", "data":
		config.FulfillmentMode = FulfillmentModeManualClaim // Default to manual claim
		config.AutoProvisionEnabled = true
		config.RequireLoginToClaim = true
	case "points":
		config.FulfillmentMode = FulfillmentModeAutoProvision
		config.AutoProvisionEnabled = true
		config.RequireLoginToClaim = false
	case "cash", "goods", "physical":
		config.FulfillmentMode = FulfillmentModeManualClaim
		config.AutoProvisionEnabled = false
		config.RequireLoginToClaim = true
	default:
		config.FulfillmentMode = FulfillmentModeManualClaim
		config.AutoProvisionEnabled = false
		config.RequireLoginToClaim = true
	}
	
	return config, nil
}

// ProcessWinnerFulfillment processes prize fulfillment based on configuration
func (s *PrizeFulfillmentService) ProcessWinnerFulfillment(ctx context.Context, winner *entities.Winner) error {
	// Get fulfillment config for this prize type
	config, err := s.GetFulfillmentConfig(ctx, winner.PrizeType)
	if err != nil {
		return fmt.Errorf("failed to get fulfillment config: %w", err)
	}
	
	// Set fulfillment mode on winner
	fulfillmentMode := string(config.FulfillmentMode)
	winner.FulfillmentMode = &fulfillmentMode
	
	// Process based on mode
	switch config.FulfillmentMode {
	case FulfillmentModeAutoProvision:
		// Auto-provision immediately
		return s.AutoProvisionPrize(ctx, winner)
		
	case FulfillmentModeManualClaim:
		// Set up for manual claim
		return s.SetupManualClaim(ctx, winner, config)
		
	default:
		return fmt.Errorf("unknown fulfillment mode: %s", config.FulfillmentMode)
	}
}

// AutoProvisionPrize automatically provisions airtime/data prizes via VTPass
func (s *PrizeFulfillmentService) AutoProvisionPrize(ctx context.Context, winner *entities.Winner) error {
	// Log provision attempt
	s.logClaimAction(ctx, winner.ID, "provision_started", "system", nil, map[string]interface{}{
		"mode": "auto_provision",
	})
	
	// Increment provision attempts
	winner.ProvisionAttempts++
	now := time.Now()
	winner.LastProvisionAttemptAt = &now
	
	// Detect network if not provided
	network := ""
	if winner.Network != nil {
		network = *winner.Network
	}
	
	if network == "" {
		detectedNetwork, err := s.hlrService.DetectNetwork(ctx, winner.MSISDN, nil)
		if err != nil {
			return s.handleProvisionFailure(ctx, winner, fmt.Sprintf("Network detection failed: %v", err))
		}
		network = detectedNetwork.Network
		winner.Network = &network
	}
	
	// Call VTPass API based on prize type
	var vtuResponse *VTUResponse
	var vtuErr error
	
	switch winner.PrizeType {
	case "airtime":
		if winner.AirtimeAmount == nil || *winner.AirtimeAmount == 0 {
			return s.handleProvisionFailure(ctx, winner, "Airtime amount not set")
		}
		
		vtuResponse, vtuErr = s.telecomServiceIntegrated.PurchaseAirtime(
			ctx,
			network,
			winner.MSISDN,
			int(*winner.AirtimeAmount), // Amount in kobo
		)
		
	case "data":
		if winner.DataPackage == nil || *winner.DataPackage == "" {
			return s.handleProvisionFailure(ctx, winner, "Data package not set")
		}
		
		// Get variation code from data package
		variationCode := *winner.DataPackage
		amount := 0
		if winner.PrizeAmount != nil {
			amount = int(*winner.PrizeAmount)
		}
		
		vtuResponse, vtuErr = s.telecomServiceIntegrated.PurchaseData(
			ctx,
			network,
			winner.MSISDN,
			variationCode,
			amount,
		)
		
	case "points":
		// Points are credited directly, no VTPass needed
		return s.handleProvisionSuccess(ctx, winner, nil)
		
	default:
		return s.handleProvisionFailure(ctx, winner, fmt.Sprintf("Prize type %s does not support auto-provision", winner.PrizeType))
	}
	
	// Handle VTPass response
	if vtuErr != nil {
		return s.handleProvisionFailure(ctx, winner, fmt.Sprintf("VTPass error: %v", vtuErr))
	}
	
	if !vtuResponse.Success {
		return s.handleProvisionFailure(ctx, winner, fmt.Sprintf("VTPass failed: %s", vtuResponse.Message))
	}
	
	// Provision succeeded
	return s.handleProvisionSuccess(ctx, winner, vtuResponse)
}

// SetupManualClaim sets up a prize for manual claiming by user
func (s *PrizeFulfillmentService) SetupManualClaim(ctx context.Context, winner *entities.Winner, config *PrizeFulfillmentConfig) error {
	// Set claim status
	winner.ClaimStatus = "unclaimed"
	
	// Set claim deadline
	claimDeadline := time.Now().AddDate(0, 0, config.ClaimDeadlineDays)
	winner.ClaimDeadline = &claimDeadline
	
	// Update winner record
	err := s.winnerRepo.Update(ctx, winner)
	if err != nil {
		return fmt.Errorf("failed to setup manual claim: %w", err)
	}
	
	// Send notification with claim instructions
	s.sendManualClaimNotification(ctx, winner, config)
	
	return nil
}

// ProcessManualClaim processes a user's manual claim request
func (s *PrizeFulfillmentService) ProcessManualClaim(ctx context.Context, winnerID uuid.UUID, msisdn string) error {
	// Get winner record
	winner, err := s.winnerRepo.FindByID(ctx, winnerID)
	if err != nil {
		return fmt.Errorf("winner not found: %w", err)
	}
	
	// Verify ownership
	if winner.MSISDN != msisdn {
		return fmt.Errorf("unauthorized: winner does not belong to this user")
	}
	
	// Check if already claimed
	if winner.ClaimStatus == "claimed" || winner.ClaimStatus == "claim_submitted" {
		return fmt.Errorf("prize already claimed")
	}
	
	// Check claim deadline
	if winner.ClaimDeadline != nil && time.Now().After(*winner.ClaimDeadline) {
		return fmt.Errorf("claim deadline has passed")
	}
	
	// Check fulfillment mode
	if winner.FulfillmentMode == nil || *winner.FulfillmentMode != "manual_claim" {
		return fmt.Errorf("this prize does not support manual claiming")
	}
	
	// Log claim initiation
	now := time.Now()
	winner.ClaimInitiatedAt = &now
	winner.ClaimButtonClicked = true
	
	s.logClaimAction(ctx, winner.ID, "claim_initiated", "user", nil, map[string]interface{}{
		"msisdn": msisdn,
	})
	
	// Process based on prize type
	switch winner.PrizeType {
	case "airtime", "data":
		// Provision via VTPass
		winner.ClaimStatus = "processing"
		s.winnerRepo.Update(ctx, winner)
		
		// Call auto-provision (same logic as auto mode)
		return s.AutoProvisionPrize(ctx, winner)
		
	case "cash", "goods", "physical":
		// These require additional details (bank account, shipping address)
		// Just mark as claim_submitted and wait for details
		winner.ClaimStatus = "claim_submitted"
		winner.ClaimedAt = &now
		return s.winnerRepo.Update(ctx, winner)
		
	default:
		return fmt.Errorf("unknown prize type: %s", winner.PrizeType)
	}
}

// RetryProvision retries failed prize provisioning
func (s *PrizeFulfillmentService) RetryProvision(ctx context.Context, winnerID uuid.UUID, initiatedBy string) error {
	winner, err := s.winnerRepo.FindByID(ctx, winnerID)
	if err != nil {
		return fmt.Errorf("winner not found: %w", err)
	}
	
	// Check if retry is allowed
	config, err := s.GetFulfillmentConfig(ctx, winner.PrizeType)
	if err != nil {
		return err
	}
	
	if !config.AllowRetryOnFailure {
		return fmt.Errorf("retry not allowed for this prize type")
	}
	
	if winner.ProvisionAttempts >= config.MaxRetryAttempts {
		return fmt.Errorf("maximum retry attempts (%d) exceeded", config.MaxRetryAttempts)
	}
	
	if winner.ProvisionStatus == nil || *winner.ProvisionStatus != "failed" {
		return fmt.Errorf("prize is not in failed state")
	}
	
	// Log retry attempt
	s.logClaimAction(ctx, winner.ID, "retry_attempted", initiatedBy, nil, map[string]interface{}{
		"attempt": winner.ProvisionAttempts + 1,
	})
	
	// Reset provision status
	provisionStatus := "pending"
	winner.ProvisionStatus = &provisionStatus
	emptyError := ""
	winner.ProvisionError = &emptyError
	
	// Retry provision
	return s.AutoProvisionPrize(ctx, winner)
}

// handleProvisionSuccess handles successful provision
func (s *PrizeFulfillmentService) handleProvisionSuccess(ctx context.Context, winner *entities.Winner, vtuResponse *VTUResponse) error {
	// Update winner status
	provisionStatus := "completed"
	winner.ProvisionStatus = &provisionStatus
	now := time.Now()
	winner.ProvisionedAt = &now
	winner.ClaimStatus = "claimed"
	winner.ClaimedAt = &now
	
	// Store VTPass transaction ID if available
	if vtuResponse != nil && vtuResponse.TransactionID != "" {
		winner.ProviderTransactionID = &vtuResponse.TransactionID
	}
	
	// Update database
	err := s.winnerRepo.Update(ctx, winner)
	if err != nil {
		return fmt.Errorf("failed to update winner after successful provision: %w", err)
	}
	
	// Log success
	s.logClaimAction(ctx, winner.ID, "provision_success", "system", nil, map[string]interface{}{
		"transaction_id": winner.ProviderTransactionID,
	})
	
	// Send success notification
	s.sendProvisionSuccessNotification(ctx, winner)
	
	return nil
}

// handleProvisionFailure handles failed provision
func (s *PrizeFulfillmentService) handleProvisionFailure(ctx context.Context, winner *entities.Winner, errorMsg string) error {
	// Update winner status
	provisionStatus := "failed"
	winner.ProvisionStatus = &provisionStatus
	winner.ProvisionError = &errorMsg
	
	// Update database
	err := s.winnerRepo.Update(ctx, winner)
	if err != nil {
		return fmt.Errorf("failed to update winner after provision failure: %w", err)
	}
	
	// Log failure
	s.logClaimAction(ctx, winner.ID, "provision_failed", "system", nil, map[string]interface{}{
		"error": errorMsg,
		"attempt": winner.ProvisionAttempts,
	})
	
	// Notify admin of failure
	s.notifyAdminOfFailedProvision(ctx, winner, errorMsg)
	
	return fmt.Errorf("provision failed: %s", errorMsg)
}

// sendManualClaimNotification sends notification for manual claim
func (s *PrizeFulfillmentService) sendManualClaimNotification(ctx context.Context, winner *entities.Winner, config *PrizeFulfillmentConfig) {
	if s.notificationService == nil {
		return
	}
	
	var message string
	if winner.PrizeType == "airtime" && winner.AirtimeAmount != nil {
		message = fmt.Sprintf("🎉 Congratulations! You won ₦%d airtime! Login to RechargeMax to claim your prize: https://rechargemax.com/wins", *winner.AirtimeAmount/100)
	} else if winner.PrizeType == "data" && winner.DataPackage != nil {
		message = fmt.Sprintf("🎉 Congratulations! You won %s data! Login to RechargeMax to claim your prize: https://rechargemax.com/wins", *winner.DataPackage)
	} else if winner.PrizeType == "cash" && winner.PrizeAmount != nil {
		message = fmt.Sprintf("🎉 Congratulations! You won ₦%d! Login to RechargeMax to claim your prize: https://rechargemax.com/wins", *winner.PrizeAmount/100)
	} else {
		message = fmt.Sprintf("🎉 Congratulations! You won %s! Login to RechargeMax to claim your prize: https://rechargemax.com/wins", winner.PrizeDescription)
	}
	
	// Send SMS
	s.notificationService.SendSMS(ctx, winner.MSISDN, message)
	
	// Send push notification
	s.notificationService.SendPushNotification(ctx, winner.MSISDN, "You Won!", message)
	
	// Create in-platform notification
	s.notificationService.CreateNotification(ctx, winner.MSISDN, "winner", "You Won!", message, map[string]interface{}{
		"winner_id": winner.ID.String(),
		"action": "claim_prize",
	})
}

// sendProvisionSuccessNotification sends notification after successful provision
func (s *PrizeFulfillmentService) sendProvisionSuccessNotification(ctx context.Context, winner *entities.Winner) {
	if s.notificationService == nil {
		return
	}
	
	var message string
	if winner.PrizeType == "data" && winner.DataPackage != nil {
		message = fmt.Sprintf("Your %s data prize has been successfully credited to %s! Enjoy! 🎉", *winner.DataPackage, winner.MSISDN)
	} else if winner.PrizeType == "airtime" && winner.AirtimeAmount != nil {
		message = fmt.Sprintf("Your ₦%d airtime prize has been successfully credited to %s! Enjoy! 🎉", *winner.AirtimeAmount/100, winner.MSISDN)
	} else {
		message = fmt.Sprintf("Your prize has been successfully credited! Enjoy! 🎉")
	}
	
	s.notificationService.SendSMS(ctx, winner.MSISDN, message)
	s.notificationService.CreateNotification(ctx, winner.MSISDN, "prize_credited", "Prize Credited", message, nil)
}

// notifyAdminOfFailedProvision notifies admin of failed provision
func (s *PrizeFulfillmentService) notifyAdminOfFailedProvision(ctx context.Context, winner *entities.Winner, errorMsg string) {
	// In production, send notification to admin dashboard or email
	// For now, just log
	fmt.Printf("ADMIN ALERT: Prize provision failed for winner %s (MSISDN: %s): %s\n", winner.ID.String(), winner.MSISDN, errorMsg)
}

// logClaimAction logs a claim/provision action to audit log
func (s *PrizeFulfillmentService) logClaimAction(ctx context.Context, winnerID uuid.UUID, action, actorType string, actorID *uuid.UUID, details map[string]interface{}) {
	// In production, insert into prize_claim_audit_log table
	// For now, just log to console
	fmt.Printf("AUDIT: winner_id=%s, action=%s, actor_type=%s, details=%v\n", winnerID.String(), action, actorType, details)
}
