// TelecomRechargeRequest represents a request to telecom provider
type TelecomRechargeRequest struct {
	MSISDN      string
	Amount      int64
	Network     string
	Type        string
	DataPackage string
	Reference   string
	CallbackURL string
}

// TelecomRechargeResponse represents response from telecom provider
type TelecomRechargeResponse struct {
	Success    bool
	Message    string
	NetworkRef string
}

// DataPackage represents a data package
type DataPackage struct {
	ID       string
	Name     string
	DataSize string
	Amount   int64
	Network  string
}
