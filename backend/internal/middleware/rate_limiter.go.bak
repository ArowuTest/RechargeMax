package middleware

import (
	"net/http"
	"sync"
	"time"

	"github.com/gin-gonic/gin"
)

// RateLimiter implements a token bucket rate limiter
type RateLimiter struct {
	visitors map[string]*Visitor
	mu       sync.RWMutex
	rate     int           // requests per window
	window   time.Duration // time window
}

// Visitor represents a single visitor's rate limit state
type Visitor struct {
	limiter  *TokenBucket
	lastSeen time.Time
}

// TokenBucket implements the token bucket algorithm
type TokenBucket struct {
	tokens    int
	capacity  int
	refillRate int
	lastRefill time.Time
	mu        sync.Mutex
}

// NewRateLimiter creates a new rate limiter
// rate: number of requests allowed per window
// window: time window duration
func NewRateLimiter(rate int, window time.Duration) *RateLimiter {
	rl := &RateLimiter{
		visitors: make(map[string]*Visitor),
		rate:     rate,
		window:   window,
	}
	
	// Start cleanup goroutine
	go rl.cleanupVisitors()
	
	return rl
}

// Allow checks if a request from the given identifier should be allowed
func (rl *RateLimiter) Allow(identifier string) bool {
	rl.mu.Lock()
	defer rl.mu.Unlock()
	
	visitor, exists := rl.visitors[identifier]
	if !exists {
		visitor = &Visitor{
			limiter:  NewTokenBucket(rl.rate, rl.rate),
			lastSeen: time.Now(),
		}
		rl.visitors[identifier] = visitor
	}
	
	visitor.lastSeen = time.Now()
	return visitor.limiter.Allow()
}

// cleanupVisitors removes stale visitors
func (rl *RateLimiter) cleanupVisitors() {
	ticker := time.NewTicker(time.Minute)
	defer ticker.Stop()
	
	for range ticker.C {
		rl.mu.Lock()
		for id, visitor := range rl.visitors {
			if time.Since(visitor.lastSeen) > 3*time.Minute {
				delete(rl.visitors, id)
			}
		}
		rl.mu.Unlock()
	}
}

// NewTokenBucket creates a new token bucket
func NewTokenBucket(capacity, refillRate int) *TokenBucket {
	return &TokenBucket{
		tokens:     capacity,
		capacity:   capacity,
		refillRate: refillRate,
		lastRefill: time.Now(),
	}
}

// Allow checks if a token is available and consumes it
func (tb *TokenBucket) Allow() bool {
	tb.mu.Lock()
	defer tb.mu.Unlock()
	
	// Refill tokens based on time elapsed
	now := time.Now()
	elapsed := now.Sub(tb.lastRefill)
	tokensToAdd := int(elapsed.Seconds()) * tb.refillRate / 60 // refill per minute
	
	if tokensToAdd > 0 {
		tb.tokens += tokensToAdd
		if tb.tokens > tb.capacity {
			tb.tokens = tb.capacity
		}
		tb.lastRefill = now
	}
	
	// Check if token available
	if tb.tokens > 0 {
		tb.tokens--
		return true
	}
	
	return false
}

// RateLimitMiddleware creates a rate limiting middleware
// rate: requests per minute
func RateLimitMiddleware(rate int) gin.HandlerFunc {
	limiter := NewRateLimiter(rate, time.Minute)
	
	return func(c *gin.Context) {
		// Use IP address as identifier
		identifier := c.ClientIP()
		
		// For authenticated users, use user ID if available
		if userID, exists := c.Get("user_id"); exists {
			identifier = userID.(string)
		}
		
		if !limiter.Allow(identifier) {
			c.JSON(http.StatusTooManyRequests, gin.H{
				"success": false,
				"message": "Rate limit exceeded. Please try again later.",
				"error":   "too_many_requests",
			})
			c.Abort()
			return
		}
		
		c.Next()
	}
}

// StrictRateLimitMiddleware creates a strict rate limiting middleware for sensitive endpoints
// rate: requests per minute (lower limit)
func StrictRateLimitMiddleware(rate int) gin.HandlerFunc {
	limiter := NewRateLimiter(rate, time.Minute)
	
	return func(c *gin.Context) {
		// Use combination of IP and user agent for stricter limiting
		identifier := c.ClientIP() + "|" + c.GetHeader("User-Agent")
		
		// For authenticated users, use user ID
		if userID, exists := c.Get("user_id"); exists {
			identifier = userID.(string)
		}
		
		if !limiter.Allow(identifier) {
			c.JSON(http.StatusTooManyRequests, gin.H{
				"success": false,
				"message": "Too many requests. Please wait before trying again.",
				"error":   "rate_limit_exceeded",
				"retry_after": 60, // seconds
			})
			c.Abort()
			return
		}
		
		c.Next()
	}
}

// OTPRateLimitMiddleware creates rate limiting specifically for OTP endpoints
func OTPRateLimitMiddleware() gin.HandlerFunc {
	limiter := NewRateLimiter(5, time.Minute) // 5 OTP requests per minute
	
	return func(c *gin.Context) {
		// Use phone number as identifier for OTP
		var requestBody struct {
			MSISDN string `json:"msisdn"`
		}
		
		if err := c.ShouldBindJSON(&requestBody); err == nil && requestBody.MSISDN != "" {
			if !limiter.Allow(requestBody.MSISDN) {
				c.JSON(http.StatusTooManyRequests, gin.H{
					"success": false,
					"message": "Too many OTP requests. Please wait 1 minute before trying again.",
					"error":   "otp_rate_limit_exceeded",
					"retry_after": 60,
				})
				c.Abort()
				return
			}
		}
		
		c.Next()
	}
}

// SpinRateLimitMiddleware creates rate limiting for spin endpoint
func SpinRateLimitMiddleware() gin.HandlerFunc {
	limiter := NewRateLimiter(10, time.Minute) // 10 spin attempts per minute (prevents spam)
	
	return func(c *gin.Context) {
		userID, exists := c.Get("user_id")
		if !exists {
			c.Next()
			return
		}
		
		identifier := userID.(string)
		
		if !limiter.Allow(identifier) {
			c.JSON(http.StatusTooManyRequests, gin.H{
				"success": false,
				"message": "Too many spin attempts. Please wait before trying again.",
				"error":   "spin_rate_limit_exceeded",
			})
			c.Abort()
			return
		}
		
		c.Next()
	}
}
