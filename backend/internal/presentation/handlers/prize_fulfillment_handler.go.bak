// PrizeFulfillmentHandler handles prize fulfillment operations
type PrizeFulfillmentHandler struct {
	fulfillmentService *services.PrizeFulfillmentService
	winnerService      *services.WinnerService
}

// NewPrizeFulfillmentHandler creates a new prize fulfillment handler
func NewPrizeFulfillmentHandler(
	fulfillmentService *services.PrizeFulfillmentService,
	winnerService      *services.WinnerService,
) *PrizeFulfillmentHandler {
	return &PrizeFulfillmentHandler{
		fulfillmentService: fulfillmentService,
		winnerService:      winnerService,
	}
}

