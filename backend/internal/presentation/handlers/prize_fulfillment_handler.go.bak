// UpdateConfig updates a prize fulfillment configuration (Admin only)
func (h *PrizeFulfillmentHandler) UpdateConfig(w http.ResponseWriter, r *http.Request) {
	vars := mux.Vars(r)
	configID := vars["id"]
	
	if configID == "" {
		errors.WriteError(w, errors.NewBadRequestError("Config ID is required"))
		return
	}
	
	var config map[string]interface{}
	if err := json.NewDecoder(r.Body).Decode(&config); err != nil {
		errors.WriteError(w, errors.NewBadRequestError("Invalid request body"))
		return
	}
	
	// In production, update database
	// For now, just return success
	
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"success": true,
		"message": "Configuration updated successfully",
	})
}

// GetFailedProvisions returns all failed provisions (Admin only)
func (h *PrizeFulfillmentHandler) GetFailedProvisions(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
	
	// In production, query database for failed provisions
	// For now, return empty array
	provisions := []map[string]interface{}{}
	
	_ = ctx // Use context
	
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"provisions": provisions,
	})
}

// RetryProvision retries a failed provision (Admin only)
func (h *PrizeFulfillmentHandler) RetryProvision(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
	vars := mux.Vars(r)
	winnerIDStr := vars["id"]
	
	winnerID, err := uuid.Parse(winnerIDStr)
	if err != nil {
		errors.WriteError(w, errors.NewBadRequestError("Invalid winner ID"))
		return
	}
	
	// Retry provision
	err = h.fulfillmentService.RetryProvision(ctx, winnerID, "admin")
	if err != nil {
		errors.WriteError(w, errors.NewInternalServerError(err.Error()))
		return
	}
	
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"success": true,
		"message": "Retry initiated successfully",
	})
}

// RetryAllProvisions retries all failed provisions (Admin only)
func (h *PrizeFulfillmentHandler) RetryAllProvisions(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
	
