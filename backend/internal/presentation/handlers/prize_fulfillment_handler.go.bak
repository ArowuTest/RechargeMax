			"autoProvisionEnabled":   true,
			"requireLoginToClaim":    true,
			"claimDeadlineDays":      30,
			"allowRetryOnFailure":    true,
			"maxRetryAttempts":       3,
			"isActive":               true,
		},
		{
			"id":                     uuid.New().String(),
			"prizeType":              "data",
			"fulfillmentMode":        "manual_claim",
			"autoProvisionEnabled":   true,
			"requireLoginToClaim":    true,
			"claimDeadlineDays":      30,
			"allowRetryOnFailure":    true,
			"maxRetryAttempts":       3,
			"isActive":               true,
		},
		{
			"id":                     uuid.New().String(),
			"prizeType":              "cash",
			"fulfillmentMode":        "manual_claim",
			"autoProvisionEnabled":   false,
			"requireLoginToClaim":    true,
			"claimDeadlineDays":      30,
			"allowRetryOnFailure":    false,
			"maxRetryAttempts":       0,
			"isActive":               true,
		},
		{
			"id":                     uuid.New().String(),
			"prizeType":              "goods",
			"fulfillmentMode":        "manual_claim",
			"autoProvisionEnabled":   false,
			"requireLoginToClaim":    true,
			"claimDeadlineDays":      30,
			"allowRetryOnFailure":    false,
			"maxRetryAttempts":       0,
