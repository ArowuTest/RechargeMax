// GetMyPrizes returns current user's prizes
func (h *PrizeFulfillmentHandler) GetMyPrizes(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
	
	// Get user MSISDN from context (set by auth middleware)
	msisdn := ctx.Value("msisdn")
	if msisdn == nil {
		errors.WriteError(w, errors.NewUnauthorizedError("User not authenticated"))
		return
	}
	
	// In production, query database for user's prizes
	// For now, return empty array
	prizes := []map[string]interface{}{}
	
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"prizes": prizes,
	})
}

// ClaimPrize allows user to claim their prize
func (h *PrizeFulfillmentHandler) ClaimPrize(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
	vars := mux.Vars(r)
	winnerIDStr := vars["id"]
	
	// Get user MSISDN from context
	msisdn := ctx.Value("msisdn")
	if msisdn == nil {
		errors.WriteError(w, errors.NewUnauthorizedError("User not authenticated"))
		return
	}
	
	winnerID, err := uuid.Parse(winnerIDStr)
	if err != nil {
		errors.WriteError(w, errors.NewBadRequestError("Invalid prize ID"))
		return
	}
	
	// Process claim
	err = h.fulfillmentService.ProcessManualClaim(ctx, winnerID, msisdn.(string))
	if err != nil {
		errors.WriteError(w, errors.NewInternalServerError(err.Error()))
		return
	}
	
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"success": true,
		"message": "Prize claimed successfully! Your reward will be delivered shortly.",
	})
}
